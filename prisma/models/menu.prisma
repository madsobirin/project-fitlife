model Menu {
  id            Int @id @default(autoincrement())
  nama_menu     String
  deskripsi     String @db.Text
  kalori        Int
  target_status String
  waktu_memasak Int
  dibaca        Int? @default(0)
  gambar        String

  created_at DateTime? @default(now())
  updated_at DateTime? @updatedAt

  @@map("menus")
}
